# machine.env.secrets — bot tokens for openclaw-hermes-watcher.
#
# ===========================================================================
# THIS FILE IS GITIGNORED. DO NOT COMMIT.
# ===========================================================================
#
# Copy this file to config/machine.env.secrets and fill in real bot tokens.
# The install scripts source this file in addition to machine.env. If a
# token here is empty, the corresponding phase / bot is skipped.
#
# Token format from @BotFather: 1234567890:ABCdef... — keep the colon.
#
# Why a separate file: we don't want bot tokens in any git repo, even a
# private one. Private GitHub repos have leaked before; this file stays on
# the machine it belongs to. When you set up a new machine, you create a
# fresh secrets file there — the per-machine `machine.env` (committed) gives
# the structure, this file (per-machine, never-committed) gives the
# credentials.
#
# Schema version (matches machine.env.example):
SCHEMA_VERSION=1

# ---------------------------------------------------------------------------
# Per-agent bot tokens. Empty = that bot/phase is skipped.
# ---------------------------------------------------------------------------
TG_BOT_MAIN_TOKEN=""                       # main router (always-on)
TG_BOT_HERMES_MAINTAINER_TOKEN=""          # Phase 1.5: hermes-maintainer
TG_BOT_HERMES_AGENT_TOKEN=""               # Phase 2:   Hermes Agent itself

# Comma-separated tokens for project subagents. Order matches
# TG_BOT_PROJECT_SUBAGENT_NAMES in machine.env. Same length, same order.
TG_BOT_PROJECT_SUBAGENT_TOKENS=""

# ---------------------------------------------------------------------------
# Heartbeat patrol bot — defaults to the maintainer's bot if set,
# otherwise main. Empty = log alerts to file only, no Telegram push.
# ---------------------------------------------------------------------------
HEARTBEAT_PATROL_BOT_TOKEN="${TG_BOT_HERMES_MAINTAINER_TOKEN:-${TG_BOT_MAIN_TOKEN}}"
