# machine.env — per-machine configuration for openclaw-hermes-watcher.
#
# Copy this file to config/machine.env and fill in the values. The render and
# install scripts source this file and substitute its variables into templates.
#
# ===========================================================================
# SECRETS LIVE IN A SEPARATE FILE — config/machine.env.secrets
# ===========================================================================
# This file (machine.env) is intended to be COMMITTED to your private fork —
# it contains your operator identity, machine identity, services description,
# bot usernames, schedules, version pins. None of those are credentials.
#
# The actual bot tokens live in config/machine.env.secrets, which is
# .gitignored and NEVER committed (not even to a private fork). See
# config/machine.env.secrets.example for the structure.
#
# Why split: even private GitHub repos are not vaults. Tokens stay on the
# machine they belong to. If you fork your private repo (e.g., for a new
# machine), you only have to recreate the secrets file there — never worry
# about token rotation breaking git history.
#
# Schema version (bumped when fields change incompatibly):
SCHEMA_VERSION=1

# ===========================================================================
# OPERATOR identity — who you are, how Hermes / maintainer should address you.
# ===========================================================================
OPERATOR_NAME="REQUIRED — your name, e.g. John Doe"
OPERATOR_EMAIL="REQUIRED — e.g. john@example.com"
OPERATOR_HANDLE="REQUIRED — short name agents use, e.g. John"
OPERATOR_LOCATION="OPTIONAL — e.g. NJ, USA — EST"
OPERATOR_LANGUAGES="OPTIONAL — e.g. English (default English)"
# Numeric Telegram user ID. Get yours by messaging @userinfobot.
# Required if you want any of the Telegram phases.
OPERATOR_TELEGRAM_USER_ID=""

# ===========================================================================
# MACHINE identity — what this host is for.
# ===========================================================================
MACHINE_NAME="REQUIRED — short slug, e.g. my-server, prod-east-1"
MACHINE_OS="OPTIONAL — e.g. Ubuntu 24.04 ARM"
MACHINE_ROLE="REQUIRED — one-line description of what this host does"

# Free-form Markdown describing the production services this host runs.
# Lands in machine-mission.md verbatim. Use \n for line breaks if needed,
# or use a here-string in your shell when sourcing.
MACHINE_SERVICES_MD="OPTIONAL — bullet list, one service per line, e.g.
- web-app: Express API on port 3000
- worker: Sidekiq background jobs"

# Things the host explicitly is NOT for. Hermes uses this to reject upstream
# suggestions that drift toward these. Free-form Markdown.
MACHINE_OUT_OF_SCOPE_MD="OPTIONAL — bullet list, e.g.
- Red-team / vulnerability scanning workflows
- Blog / CMS publishing
- Voice / TTS synthesis"

# ===========================================================================
# TELEGRAM bot USERNAMES (public — safe to commit).
# Tokens for these bots live in config/machine.env.secrets.
# ===========================================================================
# Bot usernames (the part after the @ in the bot's Telegram handle).
# To create a bot: @BotFather → /newbot → follow prompts. Username here,
# token in machine.env.secrets.
TG_BOT_MAIN_NAME=""                       # e.g. my_router_bot
TG_BOT_HERMES_MAINTAINER_NAME=""          # e.g. my_maintainer_bot      (Phase 1.5)
TG_BOT_HERMES_AGENT_NAME=""               # e.g. my_evolution_bot       (Phase 2)

# Phase 1.5 — bots for any project subagents you have. Comma-separated.
# Names list and TOKENS list (in machine.env.secrets) iterate in lockstep.
TG_BOT_PROJECT_SUBAGENT_NAMES=""          # e.g. "doom,art-review,ai-sister"
TG_BOT_PROJECT_SUBAGENT_BOTS=""           # comma-sep usernames, same order

# ===========================================================================
# HEARTBEAT PATROL — non-secret config (token in machine.env.secrets).
# ===========================================================================
# Telegram chat that receives cross-patrol alerts. Defaults to the operator's
# user ID; PII but not a credential.
HEARTBEAT_PATROL_CHAT_ID="${OPERATOR_TELEGRAM_USER_ID}"
# Tinyproxy address if your host uses one for outbound Telegram. Most setups
# leave this default; OpenClaw's gateway installer typically configures it.
HEARTBEAT_PATROL_PROXY="http://127.0.0.1:8118"

# ===========================================================================
# SCHEDULES — when each cron fires.
# ===========================================================================
# Cron expressions in 5-field format. Times are interpreted in the timezone
# below (default America/New_York). Leave defaults unless you know why.
TZ_NAME="America/New_York"
CRON_DAILY_DOCTOR="30 4 * * *"           # 04:30 local
CRON_UPSTREAM_WATCH="0 5 * * *"          # 05:00 local daily
CRON_WEEKLY_REVIEW="0 5 * * 1"           # 05:00 Monday
CRON_MONTHLY_COMPRESS="30 5 1 * *"       # 05:30 first of month

# Hermes daily-study runs in UTC (the openclaw-evolution profile is UTC-native
# because Hermes's cron is gateway-host-tz, which on Oracle defaults to UTC).
CRON_HERMES_DAILY_STUDY_UTC="0 10 * * *"  # 10:00 UTC = 06:00 EDT

# ===========================================================================
# KNOWN-GOOD VERSION PINS — auto-detected at install time if left blank.
# These guard against silent downgrades.
# ===========================================================================
KNOWN_GOOD_OPENCLAW_VERSION=""           # auto-detect via openclaw --version
KNOWN_GOOD_HERMES_VERSION=""             # auto-detect via hermes --version
KNOWN_GOOD_NODE_VERSION=""               # auto-detect via node --version
KNOWN_GOOD_PYTHON_VERSION=""             # auto-detect via python3 --version

# Git ref used when fetching the Hermes upstream installer in 03-install-hermes.sh.
# Default "main" gets you the latest upstream installer (less reproducible).
# Set to a specific tag like "v0.12.0" for reproducible installs across hosts.
HERMES_INSTALL_REF="main"
