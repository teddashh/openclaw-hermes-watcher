# Example: solo developer, one machine, minimal install.
#
# Use case: you run one or two small projects on a personal box, you want
# Hermes evolving OpenClaw to fit your workflow, you don't need Telegram bots
# (you talk via talk-* CLI). No project subagents, no Phase 2.
#
# Copy to config/machine.env and edit. Bot tokens (if you ever enable Phase
# 1.5 or 2) go in config/machine.env.secrets, never here.

SCHEMA_VERSION=1

# ===========================================================================
# OPERATOR identity
# ===========================================================================
OPERATOR_NAME="Jane Doe"
OPERATOR_EMAIL="jane@example.com"
OPERATOR_HANDLE="Jane"
OPERATOR_LOCATION="Berlin, Germany — CET"
OPERATOR_LANGUAGES="English"
OPERATOR_TELEGRAM_USER_ID=""              # leave empty if no Telegram

# ===========================================================================
# MACHINE identity
# ===========================================================================
MACHINE_NAME="dev-box"
MACHINE_OS="Ubuntu 24.04 LTS x86_64 (16GB RAM, personal workstation)"
MACHINE_ROLE="Personal development host. Runs side projects under active iteration. Used as the operator's main always-on machine for code, agent experiments, and local services."

MACHINE_SERVICES_MD="- **side-project-a** (Express + Postgres, port 4000): personal SaaS, low traffic, mainly for the operator's own tools.
- **side-project-b** (Hugo static site, served by Caddy): operator's blog. Fully static; rebuild on push."

MACHINE_OUT_OF_SCOPE_MD="- Production-grade SLAs (this is a personal box; downtime is OK)
- Multi-tenant isolation
- Security-sensitive customer data"

# Project subagents — leave empty if you don't have any.
HERMES_READ_EXTRA_PATHS_MD=""

# ===========================================================================
# TELEGRAM bots — empty = skipped
# ===========================================================================
TG_BOT_MAIN_NAME=""
TG_BOT_HERMES_MAINTAINER_NAME=""
TG_BOT_HERMES_AGENT_NAME=""

TG_BOT_PROJECT_SUBAGENT_NAMES=""
TG_BOT_PROJECT_SUBAGENT_BOTS=""

# ===========================================================================
# HEARTBEAT PATROL
# ===========================================================================
# Without OPERATOR_TELEGRAM_USER_ID, alerts log to file only, no Telegram push.
HEARTBEAT_PATROL_CHAT_ID="${OPERATOR_TELEGRAM_USER_ID}"
HEARTBEAT_PATROL_PROXY="http://127.0.0.1:8118"

# ===========================================================================
# SCHEDULES
# ===========================================================================
TZ_NAME="Europe/Berlin"
CRON_DAILY_DOCTOR="30 4 * * *"
CRON_UPSTREAM_WATCH="0 5 * * *"
CRON_WEEKLY_REVIEW="0 5 * * 1"
CRON_MONTHLY_COMPRESS="30 5 1 * *"
CRON_HERMES_DAILY_STUDY_UTC="0 4 * * *"

# ===========================================================================
# VERSIONS — leave blank to auto-detect
# ===========================================================================
KNOWN_GOOD_OPENCLAW_VERSION=""
KNOWN_GOOD_HERMES_VERSION=""
KNOWN_GOOD_NODE_VERSION=""
KNOWN_GOOD_PYTHON_VERSION=""

HERMES_INSTALL_REF="main"                 # tracks upstream; pin to a tag for reproducibility
