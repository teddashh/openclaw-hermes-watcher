# Example: multi-service production host with full Phase 1.5 + Phase 2.
#
# Use case: you run several services for real users on one VPS, each service
# is registered as an OpenClaw subagent with its own workspace and Telegram
# bot. Hermes Agent has its own bot for two-way chat (Phase 2). Cross-patrol
# heartbeat alerts via the maintainer's bot.
#
# This is the shape of the host this template was extracted from. Copy and
# adapt. Bot tokens go in config/machine.env.secrets, never here.

SCHEMA_VERSION=1

# ===========================================================================
# OPERATOR identity
# ===========================================================================
OPERATOR_NAME="Operator Name"
OPERATOR_EMAIL="operator@example.com"
OPERATOR_HANDLE="Op"
OPERATOR_LOCATION="NJ, USA — EST"
OPERATOR_LANGUAGES="English and another language"
OPERATOR_TELEGRAM_USER_ID="<numeric_id_from_userinfobot>"

# ===========================================================================
# MACHINE identity
# ===========================================================================
MACHINE_NAME="prod-host-1"
MACHINE_OS="Ubuntu Server ARM aarch64 (Oracle Cloud Ampere A1, 24GB RAM, 4 OCPU)"
MACHINE_ROLE="Production host for three live services plus a single-purpose Hermes profile (openclaw-evolution) studying OpenClaw evolution. Operator's primary always-on machine."

MACHINE_SERVICES_MD="- **service-a** (Node + Express, port 3000): public-facing API. Real users, downtime cost is measurable. Bind-mounted code at /home/ubuntu/service-a/, persistent state in Docker volume service-a-data.
- **service-b** (static gallery + Express admin tool, port 3001): SQLite at data/db.sqlite is **cloud-authoritative** — never overwrite from local. Off-host image regen pipeline.
- **service-c** (Hono + React + JWT, frontend served by Caddy): multi-user chat with auth. Auth-sensitive; secrets in .env are not to be touched."

MACHINE_OUT_OF_SCOPE_MD="- Red-team / vulnerability scanning workflows (future dedicated host)
- SharePoint / Microsoft 365 corporate connectors
- Blog / CMS publishing
- Voice / TTS synthesis
- Anything involving prowler, nessus, qualys, scubagear or other security tooling"

# Service subagents have their own workspace and MACHINE_LOG.md.
# Hermes reads these as primary food per SOUL.md service-chain framing.
HERMES_READ_EXTRA_PATHS_MD="    - ~/service-a/.openclaw-ws/MACHINE_LOG.md
    - ~/service-b/.openclaw-ws/MACHINE_LOG.md
    - ~/service-c/.openclaw-ws/MACHINE_LOG.md"

# ===========================================================================
# TELEGRAM bot USERNAMES (Phase 1.5 + Phase 2)
# ===========================================================================
# Bot tokens for these go in config/machine.env.secrets.
TG_BOT_MAIN_NAME="my_main_router_bot"
TG_BOT_HERMES_MAINTAINER_NAME="my_maintainer_bot"   # Phase 1.5
TG_BOT_HERMES_AGENT_NAME="my_evolution_bot"          # Phase 2

# Project subagents — names + bot usernames (tokens in secrets).
TG_BOT_PROJECT_SUBAGENT_NAMES="service-a,service-b,service-c"
TG_BOT_PROJECT_SUBAGENT_BOTS="my_service_a_bot,my_service_b_bot,my_service_c_bot"

# ===========================================================================
# HEARTBEAT PATROL
# ===========================================================================
HEARTBEAT_PATROL_CHAT_ID="${OPERATOR_TELEGRAM_USER_ID}"
HEARTBEAT_PATROL_PROXY="http://127.0.0.1:8118"

# ===========================================================================
# SCHEDULES
# ===========================================================================
TZ_NAME="America/New_York"
CRON_DAILY_DOCTOR="30 4 * * *"
CRON_UPSTREAM_WATCH="0 5 * * *"
CRON_WEEKLY_REVIEW="0 5 * * 1"
CRON_MONTHLY_COMPRESS="30 5 1 * *"
CRON_HERMES_DAILY_STUDY_UTC="0 10 * * *"   # 06:00 EDT

# ===========================================================================
# VERSIONS
# ===========================================================================
KNOWN_GOOD_OPENCLAW_VERSION="v2026.5.2"
KNOWN_GOOD_HERMES_VERSION="v0.12.0"
KNOWN_GOOD_NODE_VERSION="22"
KNOWN_GOOD_PYTHON_VERSION="3.10"

HERMES_INSTALL_REF="v0.12.0"
